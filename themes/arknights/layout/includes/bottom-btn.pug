//- 页面底部功能按钮：回到顶部、目录开关、主题切换、音乐开关
.bottom-btn
  div
    //- 回到顶部按钮：默认隐藏，滚动后由 JS 控制显示
    a#to-top.i-top(onClick="scrolls.scrolltop();" title=__('btn.totop') style="opacity: 0; display: none;") ∧ 
    if page.content
      - const encrypted = page.encrypt || page.password
      - const tocContent = encrypted === undefined ? toc(page.content, theme.toc) : toc(page.origin, theme.toc)
      //- 当前页面存在目录时才显示目录按钮
      if tocContent.length > 0
        a#to-index.i-index(onClick="tocControl.change()" title=__('btn.index'))
          span.tocBtnIconBar
          span.tocBtnIconBar
          span.tocBtnIconBar
    if theme.color !== 'dark-only' && theme.color !== 'light-only'
      //- 仅在允许切换主题时展示按钮
      a#color-mode.i-color(onClick="colorMode.change()" title=__('btn.colorMode'))
    if theme.bgm.enable
      //- 音乐按钮只控制播放状态，真正的 audio 节点在 layout.pug 中全局挂载
      a(onclick="BgmControl()")
        svg(id="bgm-control" viewBox="0 0 30 34" fill=theme.bgm.autoplay ? "#18d1ff" : "currentColor" style="width: 24px; transition: transform .3s;margin-top: 4px")
          path(d="M25.998 23.422V11.29h3.999v12.132h-3.999zM19.497 6.234h4.001v22.243h-4.001V6.234zM12.998.867h4v32.978h-4V.867zm-6.5 5.367h4.001v22.243H6.498V6.234zm-6.5 5.056h4v12.132h-4V11.29z") 
